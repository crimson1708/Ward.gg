{
  "name": "lolesports-site",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "next dev",
    "build": "next build",
    "start": "next start",
    "lint": "eslint",
    "ingest": "tsx scripts/ingest.mts",
    "ingest:games": "tsx scripts/ingest-games.mts",
    "ingest:news": "tsx scripts/ingest-news.mts",
    "ingest:champions": "tsx scripts/ingest-champions.mts",
    "ingest:items": "tsx scripts/ingest-items.mts",
    "ingest:runes": "tsx scripts/ingest-runes.mts",
    "ingest:draft": "tsx scripts/ingest-draft.mts",
    "ingest:stale": "tsx scripts/ingest-stale.mts",
    "refresh": "tsx scripts/ingest.mts && tsx scripts/ingest-stale.mts && tsx scripts/ingest-games.mts && tsx scripts/ingest-news.mts",
    "watch": "tsx scripts/watch.mts",
    "postinstall": "prisma generate",
    "setup:db": "prisma migrate deploy"
  },
  "dependencies": {
    "@libsql/client": "^0.17.4",
    "@prisma/adapter-better-sqlite3": "^7.8.0",
    "@prisma/adapter-libsql": "^7.9.0",
    "@prisma/client": "^7.8.0",
    "better-sqlite3": "^12.11.1",
    "next": "16.2.10",
    "react": "19.2.4",
    "react-dom": "19.2.4"
  },
  "devDependencies": {
    "@types/node": "^20",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "dotenv": "^17.4.2",
    "eslint": "^9",
    "eslint-config-next": "16.2.10",
    "prisma": "^7.8.0",
    "tsx": "^4.23.0",
    "typescript": "^5"
  }
}
