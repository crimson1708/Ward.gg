// This is your Prisma schema file — the single source of truth for your database.
// Change a model here, run `npx prisma migrate dev`, and Prisma updates the real
// SQLite tables AND regenerates the typed client you query with.

generator client {
  provider = "prisma-client"
  output   = "../app/generated/prisma"
}

datasource db {
  provider = "sqlite"
}

// ─────────────────────────────────────────────────────────────────────────────
// A note on two recurring fields you'll see on almost every model:
//   externalId  = the ID the LoL Esports API uses for this thing. We store it and
//                 mark it @unique so ingestion can "upsert" (insert-or-update)
//                 without ever creating duplicates when a job re-runs.
//   id          = OUR own database id (a simple auto-incrementing number).
// ─────────────────────────────────────────────────────────────────────────────

// A competition circuit: LEC, LCK, LPL, MSI, Worlds...
model League {
  id          Int          @id @default(autoincrement())
  externalId  String       @unique
  name        String
  region      String
  slug        String       @unique // url-friendly, e.g. "lec" -> /leagues/lec
  tournaments Tournament[]
  matches     Match[] // the schedule keys matches to a league directly
}

// A specific season/split of a league, e.g. "LEC Summer 2026".
model Tournament {
  id         Int      @id @default(autoincrement())
  externalId String   @unique
  name       String
  slug       String   @unique
  league     League   @relation(fields: [leagueId], references: [id])
  leagueId   Int
  matches    Match[]
}

model Team {
  id         Int        @id @default(autoincrement())
  externalId String     @unique
  name       String
  code       String // the 3-4 letter tag, e.g. "T1", "PLS"
  slug       String     @unique
  logoUrl    String?
  region     String?
  players    Player[] // current roster
  // A team shows up in matches as either side A or side B, so we need two
  // named relations pointing back here (Prisma requires naming when a model
  // relates to another model more than once).
  matchesAsA Match[]    @relation("MatchTeamA")
  matchesAsB Match[]    @relation("MatchTeamB")
  gameStats  GameStat[]
}

model Player {
  id         Int        @id @default(autoincrement())
  externalId String     @unique
  handle     String // in-game name, e.g. "Faker"
  realName   String?
  role       String? // top | jungle | mid | bottom | support
  country    String?
  // A player's CURRENT team. Nullable because free agents exist. Historical
  // team-per-game is recoverable from GameStat below.
  team       Team?      @relation(fields: [teamId], references: [id])
  teamId     Int?
  gameStats  GameStat[]
}

// A MATCH is the series (Bo1/Bo3/Bo5) — the thing you see on a schedule page.
model Match {
  id         Int    @id @default(autoincrement())
  externalId String @unique

  // The schedule gives us the league (by slug), so this link is required.
  league   League @relation(fields: [leagueId], references: [id])
  leagueId Int

  // Tournament isn't in the schedule feed — it's an optional future enrichment.
  tournament   Tournament? @relation(fields: [tournamentId], references: [id])
  tournamentId Int?

  startTime DateTime
  status    String // "unstarted" | "inProgress" | "completed"  (SQLite has no enum type)
  bestOf    Int // 1, 3, or 5

  teamA   Team @relation("MatchTeamA", fields: [teamAId], references: [id])
  teamAId Int
  teamB   Team @relation("MatchTeamB", fields: [teamBId], references: [id])
  teamBId Int
  scoreA  Int  @default(0) // games won by team A in the series
  scoreB  Int  @default(0)

  // Plain nullable id (not a full relation) to keep the schema readable —
  // it just records which team's id won the series, if finished.
  winnerTeamId Int?

  games Game[]
}

// A GAME is one map within a series. A Bo3 that ends 2-0 has a 3rd game that
// was never played, so games carry their own state.
model Game {
  id           Int        @id @default(autoincrement())
  externalId   String     @unique
  match        Match      @relation(fields: [matchId], references: [id])
  matchId      Int
  number       Int // 1, 2, 3... within the series
  state        String // "completed" | "unneeded" | "inProgress" | "unstarted"
  patch        String?
  durationSecs Int?
  winnerTeamId Int?
  stats        GameStat[]
}

// One row PER PLAYER PER GAME — this is the detailed box score you pulled from
// the feed API (champion, K/D/A, CS, gold). The heart of your stats pages.
model GameStat {
  id         Int    @id @default(autoincrement())
  game       Game   @relation(fields: [gameId], references: [id])
  gameId     Int
  player     Player @relation(fields: [playerId], references: [id])
  playerId   Int
  team       Team   @relation(fields: [teamId], references: [id])
  teamId     Int
  side       String // "BLUE" | "RED"
  role       String // top | jungle | mid | bottom | support
  champion   String
  kills      Int
  deaths     Int
  assists    Int
  creepScore Int
  totalGold  Int

  // A player only appears once per game, so this pair is unique — again enables
  // safe upserts during ingestion.
  @@unique([gameId, playerId])
}
